            class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100"
          >
            <h3 class="font-semibold text-gray-900 text-xl mb-6">
              Work with us
            </h3>
            <div class="grid grid-cols-2 gap-6">
              <div>
                <div class="text-3xl font-bold gradient-text">12</div>
                <div class="text-gray-500 text-sm">Offices worldwide</div>
              </div>
              <div>
                <div class="text-3xl font-bold gradient-text">300+</div>
                <div class="text-gray-500 text-sm">Full-time colleagues</div>
              </div>
