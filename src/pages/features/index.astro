---
import Layout from "@/src/layouts/Layout.astro";
import Footer from "@/src/components/Footer.astro";
import { Button } from "@/components/ui/button";
import "../../styles/global.css";
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Features - RyuLabs</title>
    <meta
      name="description"
      content="Fitur-fitur canggih RyuLabs untuk memperkaya bisnis online Anda."
    />

    <!-- Tailwind CSS CDN + konfigurasi dasar -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Custom styling untuk meniru persis style home page -->
    <style>
      body {
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
      }
      /* Efek transisi untuk kartu dan tombol */
      .card-hover {
        transition: all 0.2s ease;
      }
      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow:
          0 20px 25px -5px rgba(0, 0, 0, 0.05),
          0 10px 10px -5px rgba(0, 0, 0, 0.01);
      }
      .gradient-text {
        background: linear-gradient(to right, #3b82f6, #a855f7);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
    </style>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <!-- Navigation Bar - Mirip persis dengan home -->
    <nav
      class="border-b border-gray-100 bg-white/80 backdrop-blur-sm sticky top-0 z-50"
    >
      <div
        class="container mx-auto px-6 py-4 flex justify-between items-center"
      >
        <!-- Logo -->
        <div class="text-2xl font-bold">
          <span class="gradient-text">RyuLabs</span>
        </div>

        <!-- Menu Tengah -->
        <div class="hidden md:flex space-x-8 text-gray-600 font-medium">
          <a href="/" class="hover:text-gray-900 transition">Product</a>
          <a
            href="/features"
            class="text-gray-900 font-semibold border-b-2 border-blue-500 pb-1"
            >Features</a
          >
          <a href="#" class="hover:text-gray-900 transition">Marketplace</a>
          <a href="#" class="hover:text-gray-900 transition">Company</a>
        </div>

        <!-- Tombol Login -->
        <div>
          <a
            href="#"
            class="text-gray-600 hover:text-gray-900 transition font-medium"
          >
        <Button>LOGIN</Button>  
        </a>
        </div>
      </div>
    </nav>

    <!-- Hero Section Features -->
    <section class="py-20 px-6 text-center">
      <div class="container mx-auto max-w-3xl">
        <h1
          class="text-5xl md:text-6xl font-bold tracking-tight bg-gradient-to-r from-gray-900 via-gray-800 to-gray-700 bg-clip-text text-transparent"
        >
          Fitur untuk
          <span class="gradient-text">Bisnis Online</span>
        </h1>
        <p class="text-xl text-gray-500 mt-6 leading-relaxed">
          Anim aute id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem
          cupidatat commodo. Elit sunt amet fugiat veniam occaecat.
        </p>
        <div class="flex gap-4 justify-center mt-8">
          <a
            href="#"
            class="bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition shadow-sm"
            >Get started</a
          >
          <a
            href="#"
            class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition"
            >Learn more</a
          >
        </div>
      </div>
    </section>

    <!-- Grid Fitur Utama - 3 kolom, mirip gaya kartu home -->
